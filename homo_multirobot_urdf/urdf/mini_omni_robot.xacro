<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mini_omni_robot">

  <xacro:arg name="prefix" default=""/>
  <xacro:arg name="use_gazebo" default="true"/>
  <!-- true: use ros2_control + gazebo_ros2_control; false: fallback to gazebo_ros_planar_move -->
  <xacro:arg name="use_ros2_control" default="false"/>
  <!-- 留空表示不额外设置；若 launch 里为每台机器人设置了命名空间，这里会把插件节点放进该 namespace -->
  <xacro:arg name="ros_namespace" default=""/>
  <!-- gazebo_ros_planar_move: toggle odom topic / TF publication -->
  <xacro:arg name="planar_publish_odom" default="true"/>
  <xacro:arg name="planar_publish_odom_tf" default="true"/>

  <xacro:property name="p" value="$(arg prefix)"/>

  <!-- Simple primitive collision (more stable than mesh collision in Gazebo) -->
  <!-- base_link collision box size (meters) -->
  <xacro:property name="base_collision_size_x" value="0.24"/>
  <xacro:property name="base_collision_size_y" value="0.20"/>
  <xacro:property name="base_collision_size_z" value="0.10"/>
  <!-- wheel collision cylinder (meters): axis will be rotated to align with wheel joint axis -->
  <!-- Keep consistent with controller config convention (often r=0.03) -->
  <xacro:property name="wheel_collision_radius" value="0.03"/>
  <xacro:property name="wheel_collision_width" value="0.020"/>
  <!-- Small lift to avoid initial penetration / physics instability -->
  <xacro:property name="wheel_collision_z_offset" value="0.007"/>
  <!-- Gazebo contact: set wheel friction low to avoid yaw drift in planar_move mode -->
  <xacro:property name="wheel_mu" value="0.0"/>
  <xacro:property name="wheel_mu2" value="0.0"/>

  <xacro:if value="$(arg use_ros2_control)">
    <ros2_control name="${p}mini_omni_robot_system" type="system">
      <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      </hardware>

      <joint name="${p}front_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="${p}left_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="${p}right_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>
  </xacro:if>

  <link name="${p}base_footprint"/>

  <joint name="${p}base_footprint_joint" type="fixed">
    <origin xyz="0 0 0.06" rpy="0 0 0" />
    <parent link="${p}base_footprint" />
    <child link="${p}base_link" />
  </joint>

  <link name="${p}base_link">
    <inertial>
      <origin xyz="-0.00215152015512567 -0.00354771497616371 -0.00238850986636495" rpy="0 0 0" />
      <mass value="0.316971084822964" />
      <inertia
        ixx="0.000420307413554536"
        ixy="8.53304678996615E-07"
        ixz="3.25484281157172E-11"
        iyy="0.000423240319736897"
        iyz="-2.92206846665081E-11"
        izz="0.000803923344739989" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/base_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.741176470588235 0.901960784313726 0.956862745098039 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="${p}imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6" />
    </inertial>
  </link>

  <joint name="${p}imu_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="${p}base_link" />
    <child link="${p}imu_link" />
  </joint>

  <link name="${p}front_wheel_link">
    <inertial>
      <origin xyz="5.74714974423331E-05 0.00320699063859495 -4.61768854820438E-05" rpy="0 0 0" />
      <mass value="0.0418742906509581" />
      <inertia
        ixx="1.11530020202845E-05"
        ixy="2.36675244306518E-08"
        ixz="-5.43279459256917E-08"
        iyy="1.8768089937325E-05"
        iyz="-4.01883681793204E-08"
        izz="1.11464768270902E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/front_wheel_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.376470588235294 0.376470588235294 0.376470588235294 1" />
      </material>
    </visual>
    <collision>
      <!-- URDF cylinder axis is +Z; rotate to align with wheel joint axis (±Y) -->
      <origin xyz="0 0 ${wheel_collision_z_offset}" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="${wheel_collision_radius}" length="${wheel_collision_width}" />
      </geometry>
    </collision>
  </link>

  <joint name="${p}front_wheel_joint" type="continuous">
    <!-- z tuned to keep wheel above ground at spawn (avoid initial penetration) -->
    <origin xyz="0.10975 8.5571E-05 -0.0300" rpy="0 0 1.5708" />
    <parent link="${p}base_link" />
    <child link="${p}front_wheel_link" />
    <axis xyz="0 -1 0" />
  </joint>

  <link name="${p}left_wheel_link">
    <inertial>
      <origin xyz="5.74678573044898E-05 0.00320699471167032 -4.61750060654284E-05" rpy="0 0 0" />
      <mass value="0.041874288756166" />
      <inertia
        ixx="1.11530017211417E-05"
        ixy="2.36641581685783E-08"
        ixz="-5.43274481797102E-08"
        iyy="1.87681100612576E-05"
        iyz="-4.01888165769215E-08"
        izz="1.11464785833887E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/left_wheel_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.376470588235294 0.376470588235294 0.376470588235294 1" />
      </material>
    </visual>
    <collision>
      <!-- URDF cylinder axis is +Z; rotate to align with wheel joint axis (±Y) -->
      <origin xyz="0 0 ${wheel_collision_z_offset}" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="${wheel_collision_radius}" length="${wheel_collision_width}" />
      </geometry>
    </collision>
  </link>

  <joint name="${p}left_wheel_joint" type="continuous">
    <!-- z tuned to keep wheel above ground at spawn (avoid initial penetration) -->
    <origin xyz="-0.054729 0.095045 -0.0300" rpy="0 0 -2.618" />
    <parent link="${p}base_link" />
    <child link="${p}left_wheel_link" />
    <axis xyz="0 -1 0" />
  </joint>

  <link name="${p}right_wheel_link">
    <inertial>
      <origin xyz="5.74721854603097E-05 0.00320699380279695 -4.61761038215297E-05" rpy="0 0 0" />
      <mass value="0.0418742868228469" />
      <inertia
        ixx="1.11530020877519E-05"
        ixy="2.36755527469659E-08"
        ixz="-5.43278673691997E-08"
        iyy="1.87681107970762E-05"
        iyz="-4.0189135655947E-08"
        izz="1.11464784876816E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/right_wheel_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.376470588235294 0.376470588235294 0.376470588235294 1" />
      </material>
    </visual>
    <collision>
      <!-- URDF cylinder axis is +Z; rotate to align with wheel joint axis (±Y) -->
      <origin xyz="0 0 ${wheel_collision_z_offset}" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="${wheel_collision_radius}" length="${wheel_collision_width}" />
      </geometry>
    </collision>
  </link>

  <joint name="${p}right_wheel_joint" type="continuous">
    <!-- z tuned to keep wheel above ground at spawn (avoid initial penetration) -->
    <origin xyz="-0.054729 -0.094874 -0.0300" rpy="0 0 -0.5236" />
    <parent link="${p}base_link" />
    <child link="${p}right_wheel_link" />
    <axis xyz="0 -1 0" />
  </joint>

  <!-- Gazebo wheel contact tuning (reduce unintended steering torque) -->
  <gazebo reference="${p}front_wheel_link">
    <mu1>${wheel_mu}</mu1>
    <mu2>${wheel_mu2}</mu2>
  </gazebo>
  <gazebo reference="${p}left_wheel_link">
    <mu1>${wheel_mu}</mu1>
    <mu2>${wheel_mu2}</mu2>
  </gazebo>
  <gazebo reference="${p}right_wheel_link">
    <mu1>${wheel_mu}</mu1>
    <mu2>${wheel_mu2}</mu2>
  </gazebo>

  <link name="${p}controller_link">
    <inertial>
      <origin xyz="-0.0166307508329173 0.0377059276016881 0.0221732694812525" rpy="0 0 0" />
      <mass value="0.0388361502106471" />
      <inertia
        ixx="2.23207514180048E-05"
        ixy="9.5272750875175E-07"
        ixz="-5.84384794338806E-08"
        iyy="2.46082780117255E-05"
        iyz="3.14216783338302E-07"
        izz="4.60494109024797E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/controller_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.741176470588235 0.901960784313726 0.956862745098039 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/controller_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="${p}controller_joint" type="fixed">
    <origin xyz="-0.05003 -0.044286 0.0515" rpy="0 0 0" />
    <parent link="${p}base_link" />
    <child link="${p}controller_link" />
    <axis xyz="0 0 0" />
  </joint>

  <link name="${p}laser_link">
    <inertial>
      <origin xyz="0.0023946067243534 -4.3623586159597E-06 0.00454035676315102" rpy="0 0 0" />
      <mass value="0.0391766918292892" />
      <inertia
        ixx="2.82296075691487E-05"
        ixy="-2.19900290000419E-09"
        ixz="1.07118438746105E-06"
        iyy="3.37984497834087E-05"
        iyz="6.83963658170686E-10"
        izz="4.50920076493152E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/laser.STL" />
      </geometry>
      <material name="">
        <color rgba="0.376470588235294 0.376470588235294 0.376470588235294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/laser.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="${p}laser_joint" type="fixed">
    <origin xyz="0.005095 8.5571E-05 0.097524" rpy="0 0 0" />
    <parent link="${p}base_link" />
    <child link="${p}laser_link" />
    <axis xyz="0 0 0" />
  </joint>

  <link name="${p}camera_link">
    <inertial>
      <origin xyz="-1.30544696302914E-07 -9.32154475080064E-08 1.07624265707762E-07" rpy="0 0 0" />
      <mass value="0.0559842512081409" />
      <inertia
        ixx="0.000130810959339877"
        ixy="1.20255128069094E-07"
        ixz="1.62335437079563E-06"
        iyy="1.91148634968207E-05"
        iyz="-2.80016756154036E-08"
        izz="0.00013138746952371" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/camera_link.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://homo_multirobot_urdf/meshes/mini_omni_robot_meshes/camera_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="${p}camera_joint" type="fixed">
    <origin xyz="0.085700005871124 0.000163315147966551 0.076204" rpy="0 0 0" />
    <parent link="${p}base_link" />
    <child link="${p}camera_link" />
    <axis xyz="0 0 0" />
  </joint>

  <xacro:if value="$(arg use_gazebo)">
    <!-- Ray lidar: publishes `<ns>/scan` -->
    <gazebo reference="${p}laser_link">
      <sensor name="${p}lidar" type="ray">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <visualize>true</visualize>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.141592653589793</min_angle>
              <max_angle>3.141592653589793</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <!-- ROS2：默认话题为 ~/out；用 remapping 得到 /<ns>/scan，并用 LaserScan -->
        <plugin name="${p}gazebo_ros_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <namespace>$(arg ros_namespace)</namespace>
            <remapping>~/out:=scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>${p}laser_link</frame_name>
        </plugin>
      </sensor>
    </gazebo>

    <!-- IMU: publishes `<ns>/imu` -->
    <gazebo reference="${p}imu_link">
      <sensor name="${p}imu" type="imu">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <visualize>false</visualize>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0002</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.02</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.02</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.02</stddev></noise></z>
          </linear_acceleration>
        </imu>
        <!-- ROS2：默认 ~/out；remapping 得到 /<ns>/imu -->
        <plugin name="${p}gazebo_ros_imu_sensor" filename="libgazebo_ros_imu_sensor.so">
          <ros>
            <namespace>$(arg ros_namespace)</namespace>
            <remapping>~/out:=imu</remapping>
          </ros>
        </plugin>
      </sensor>
    </gazebo>

    <!-- Planar move + odom: subscribes `<ns>/cmd_vel`, publishes `<ns>/odom` and TF -->
    <xacro:if value="$(arg use_ros2_control)">
      <gazebo>
        <plugin name="${p}gazebo_ros2_control" filename="libgazebo_ros2_control.so">
          <ros>
            <namespace>$(arg ros_namespace)</namespace>
          </ros>
        </plugin>
      </gazebo>
    </xacro:if>

    <xacro:unless value="$(arg use_ros2_control)">
      <gazebo>
        <plugin name="${p}gazebo_ros_planar_move" filename="libgazebo_ros_planar_move.so">
          <ros>
            <namespace>$(arg ros_namespace)</namespace>
          </ros>
          <command_topic>cmd_vel</command_topic>
          <odometry_topic>odom</odometry_topic>
          <odometry_frame>${p}odom</odometry_frame>
          <robot_base_frame>${p}base_footprint</robot_base_frame>
          <publish_odom>$(arg planar_publish_odom)</publish_odom>
          <publish_odom_tf>$(arg planar_publish_odom_tf)</publish_odom_tf>
        </plugin>
      </gazebo>
    </xacro:unless>
  </xacro:if>

</robot>

